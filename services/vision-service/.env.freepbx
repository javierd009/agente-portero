# Vision Service - FreePBX Environment Configuration
# Copy this file and fill in your camera details:
#   cp .env.freepbx .env

# ===========================================
# HIKVISION CAMERA (CONFIGURE THESE)
# ===========================================
HIKVISION_HOST=192.168.1.100
HIKVISION_PORT=80
HIKVISION_USER=admin
HIKVISION_PASSWORD=your_camera_password

# ===========================================
# BACKEND API (DO NOT CHANGE)
# ===========================================
BACKEND_API_URL=https://api-portero.integratec-ia.com

# ===========================================
# DETECTION SETTINGS (OPTIONAL)
# ===========================================
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
OCR_LANGUAGE=es

# ===========================================
# SERVICE SETTINGS (OPTIONAL)
# ===========================================
SERVICE_PORT=8001
DEBUG=false
